    },
    "Welcome, Cowboy. Only one rule in these parts, the quickest draw win. You've got 3 shots to win. Make 'em count." : {
      "localizations" : {
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Selamat datang, Cowboy. Di sini cuma ada satu aturan: penembak tercepat menang. Kamu punya 3 tembakan untuk menang. Jangan sampai meleset."
          }
        }
      }
    },
    "What's your name, Slinger?" : {
      "localizations" : {
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Siapa namamu, Slinger?"
          }
        }
      }
    },

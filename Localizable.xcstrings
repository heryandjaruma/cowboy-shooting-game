    "Each player has **3 lives**. The last one standing will take the match." : {
      "localizations" : {
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Setiap pemain memiliki **3 nyawa**. Pemain terakhir yang bertahan memenangkan pertandingan."
